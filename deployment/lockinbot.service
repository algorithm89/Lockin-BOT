[Unit]
Description=LockIn Bot - Accountability SMS/Voice Bot
After=network.target mysql.service

[Service]
User=root
Group=root
WorkingDirectory=/var/www/lockinbot
EnvironmentFile=/var/www/lockinbot/.env
ExecStart=/var/www/lockinbot/venv/bin/gunicorn --workers 1 --bind 0.0.0.0:5000 --timeout 120 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target


