[Unit]
Description=LockIn Bot - Accountability SMS/Voice Bot
After=network.target docker.service

[Service]
User=root
Group=root
WorkingDirectory=/home/bublik/Lockin-BOT
EnvironmentFile=/home/bublik/Lockin-BOT/.env
ExecStart=/home/bublik/Lockin-BOT/venv/bin/gunicorn --workers 1 --worker-class gevent --bind 0.0.0.0:5000 --timeout 120 --preload wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target





